# ══════════════════════════════════════════════════════════════════════════════
# Bot D — LoL Polymarket Trading Bot — Variables de Entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env al repo.
# ══════════════════════════════════════════════════════════════════════════════

# ── Polymarket ────────────────────────────────────────────────────────────────
# Private key de tu wallet Polygon (hex, con 0x)
POLYMARKET_PRIVATE_KEY=0x...

# Proxy wallet address de Polymarket (ver docs CLOB)
POLYMARKET_PROXY_ADDRESS=0x...

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxx...
TELEGRAM_CHAT_ID=-100...

# ── LoL Esports API ───────────────────────────────────────────────────────────
LOLESPORTS_BASE_URL=https://feed.lolesports.com/livestats/v1

# ── Gestión de riesgo ─────────────────────────────────────────────────────────
BANKROLL=1000
MIN_EDGE_THRESHOLD=0.08      # 8% mínimo de edge para entrar
MAX_POSITION_SIZE_USD=50     # máximo $50 USDC por trade
MIN_MARKET_LIQUIDITY=500     # no operar si liquidez < $500

# ── Operación ─────────────────────────────────────────────────────────────────
# SIEMPRE true hasta validar los 6 criterios de éxito manualmente
DRY_RUN=true

# ── Rutas ─────────────────────────────────────────────────────────────────────
DB_PATH=lol_bot.db
MODEL_PATH=backend/model/model.pkl
